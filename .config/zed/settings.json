{
  "icon_theme": {
    "mode": "light",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Vague",
  },
  "buffer_font_family": "Iosevka Term",
  "buffer_font_size": 18,
  "ui_font_family": ".SystemUIFont",
  "ui_font_size": 16,
  "buffer_line_height": { "custom": 1.4 },
  "buffer_font_features": { "calt": false },
  "tab_size": 2,
  "hard_tabs": false,
  "soft_wrap": "none",
  "show_wrap_guides": false,
  "relative_line_numbers": true,
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "indent_guides": {
    "enabled": true,
  },
  "scrollbar": {
    "show": "never",
  },
  "vim_mode": true,
  "load_direnv": "shell_hook",
  "format_on_save": "on",
  "terminal": {
    "font_family": "Iosevka Term",
    "working_directory": "current_project_directory",
  },
  "disable_ai": true,
  "agent": {
    "enabled": false,
  },
}
